{
  "name": "mcp-feedback-enhanced-frontend",
  "version": "0.1.0",
  "description": "Frontend for MCP Feedback Enhanced - Vue.js 3 + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@vueuse/core": "^10.5.0",
    "axios": "^1.6.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.0.0",
    "sass": "^1.69.0",
    "terser": "^5.41.0",
    "typescript": "~5.2.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "vue",
    "vite",
    "typescript",
    "mcp",
    "feedback",
    "websocket",
    "frontend"
  ],
  "author": "MCP Feedback Enhanced Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Minidoracat/mcp-feedback-enhanced.git"
  },
  "bugs": {
    "url": "https://github.com/Minidoracat/mcp-feedback-enhanced/issues"
  },
  "homepage": "https://github.com/Minidoracat/mcp-feedback-enhanced#readme"
}
